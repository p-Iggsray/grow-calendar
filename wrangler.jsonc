{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "grow-calendar",
  "main": "./worker/index.js",
  "compatibility_date": "2026-05-23",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "grow-calendar-db",
      "database_id": "REPLACE_WITH_DB_ID_FROM_WRANGLER_D1_CREATE"
    }
  ],
  "observability": {
    "enabled": true
  }
}
